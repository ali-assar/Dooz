ENVIRONMENT=development
HTTP_PORT=8080
SECRET=choose_a_better_secret
DATABASE_HOST=postgres://postgres:your_password@localhost:5412/dooz?sslmode=disable
REDIS_HOST=localhost:6312

# super user
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PHONE=09000000000
SUPER_ADMIN_PASSWORD=your-secure-password

# sms (set SMS_PROVIDER=2 for no-op / log-only mode — good for development) set 3 for smsir 1 for message way
SMS_PROVIDER=2
SMS_API_KEY=YOUR_APIKEY
SMS_OTP_TEMPLATE_ID=1

# SMTP email
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your_app_password
SMTP_SENDER=noreply@example.com

# Set EMAIL_PROVIDER=2 for no-op (log only)
EMAIL_PROVIDER=2

# Cloudflare Turnstile (optional bot protection)
CLOUDFLARE_TURNSTILE_ENABLED=false
CLOUDFLARE_TURNSTILE_SECRET_KEY=your_secret_key_here
